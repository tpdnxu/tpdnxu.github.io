[{"title":"Stunning Coding Fonts","url":"/2024/09/22/Stunning-Coding-Fonts/","content":"<p><a href=\"https://fonts.google.com/specimen/Fira+Code?query=fira&classification=Monospace\">Fira Code</a><br><img src=\"https://miro.medium.com/v2/resize:fit:828/format:webp/0*M8OwSeV8gKvw1gd4.png\"></p>\n<span id=\"more\"></span>\n<p><a href=\"https://fontlibrary.org/en/font/fantasque-sans-mono\">Fantasque Sans Mono</a><br><img src=\"https://miro.medium.com/v2/resize:fit:828/format:webp/0*ZW6aTJ6suU_5B_yV.png\"></p>\n<p><a href=\"https://fonts.google.com/specimen/Inconsolata?query=inconsolata&classification=Monospace\">Inconsolata</a><br><img src=\"https://miro.medium.com/v2/resize:fit:828/format:webp/0*M8OwSeV8gKvw1gd4.png\"></p>\n<p><a href=\"https://fonts.google.com/specimen/Roboto+Mono?query=roboto&classification=Monospace\">Roboto Mono</a><br><img src=\"https://miro.medium.com/v2/resize:fit:828/format:webp/0*4zaS3OVdupsSkqTR.png\"></p>\n<p><a href=\"https://github.com/microsoft/cascadia-code\">Cascadia Code</a><br><img src=\"https://miro.medium.com/v2/resize:fit:828/format:webp/0*gLY8oRI0BCOO0kDI.png\"></p>\n<p><a href=\"https://fonts.google.com/specimen/Comic+Neue?query=comic&classification=Display\">Comic Neue</a><br><img src=\"https://miro.medium.com/v2/resize:fit:828/format:webp/0*6WtP2WS_KP_xex6n.png\"></p>\n<p><a href=\"https://fonts.google.com/specimen/Pixelify+Sans\">Pixelify Sans</a><br><img src=\"https://miro.medium.com/v2/resize:fit:828/format:webp/0*QHmkh_RQihg392ff.png\"></p>\n<p><a href=\"https://fonts.google.com/specimen/Victor+Mono\">Victor Mono</a><br><img src=\"https://miro.medium.com/v2/resize:fit:828/format:webp/0*x5rikYfckh7yVowE.png\"></p>\n<p><a href=\"https://fonts.google.com/specimen/JetBrains+Mono\">JetBrains Mono</a><br><img src=\"https://miro.medium.com/v2/resize:fit:828/format:webp/0*7U3LF2LA4nMe_q0o.png\"></p>\n<p><a href=\"https://fonts.google.com/noto/specimen/Noto+Sans+Mono\">Noto Sans Mono</a><br><img src=\"https://miro.medium.com/v2/resize:fit:828/format:webp/0*L0WzHfjzA5vmYjRz.png\"></p>\n<p><a href=\"https://fonts.google.com/specimen/Anonymous+Pro?query=Anon&classification=Monospace\">Anonymous Pro</a><br><img src=\"https://miro.medium.com/v2/resize:fit:828/format:webp/0*xDVyBOf1iTI2fr5H.png\"></p>\n","categories":["其他"],"tags":["others"]},{"title":"WSL通過導入鏡像安裝CentOS9","url":"/2024/09/22/WSL%E9%80%9A%E9%81%8E%E5%B0%8E%E5%85%A5%E9%8F%A1%E5%83%8F%E5%AE%89%E8%A3%9DCentOS9/","content":"<h4 id=\"下載鏡像\"><a href=\"#下載鏡像\" class=\"headerlink\" title=\"下載鏡像\"></a>下載鏡像</h4><figure class=\"highlight bash\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># 下載CentOS9</span></span><br><span class=\"line\">- https://github.com/mishamosher/CentOS-WSL/releases/tag/9-stream-20230626</span><br></pre></td></tr></table></figure>\n<span id=\"more\"></span>\n<h4 id=\"導入鏡像\"><a href=\"#導入鏡像\" class=\"headerlink\" title=\"導入鏡像\"></a>導入鏡像</h4><figure class=\"highlight bash\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># wsl --import &lt;DistributionName&gt; &lt;InstallLocation&gt; &lt;FileName&gt;</span></span><br><span class=\"line\">$ wsl --import CentOS9 C:\\AppServ\\centos rootfs.tar.gz</span><br></pre></td></tr></table></figure>\n\n<h4 id=\"啟動系統\"><a href=\"#啟動系統\" class=\"headerlink\" title=\"啟動系統\"></a>啟動系統</h4><figure class=\"highlight bash\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># 登入系統</span></span><br><span class=\"line\">$ wsl --distribution CentOS9</span><br></pre></td></tr></table></figure>\n\n<figure class=\"highlight bash\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># 更新系統</span></span><br><span class=\"line\">$ <span class=\"built_in\">sudo</span> yum -y update</span><br></pre></td></tr></table></figure>\n\n<h4 id=\"缷載系統\"><a href=\"#缷載系統\" class=\"headerlink\" title=\"缷載系統\"></a>缷載系統</h4><figure class=\"highlight bash\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># 移除系統</span></span><br><span class=\"line\">$ wsl --unregister CentOS9</span><br></pre></td></tr></table></figure>","categories":["應用工具"],"tags":["WSL","CentOS"]},{"title":"使用Oh My Posh美化終端介面","url":"/2024/09/22/%E4%BD%BF%E7%94%A8Oh-My-Posh%E7%BE%8E%E5%8C%96%E7%B5%82%E7%AB%AF%E4%BB%8B%E9%9D%A2/","content":"<p><img src=\"/images/ohmyposh.jpg\"></p>\n<span id=\"more\"></span>\n<h4 id=\"下載安裝\"><a href=\"#下載安裝\" class=\"headerlink\" title=\"下載安裝\"></a>下載安裝</h4><figure class=\"highlight bash\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># 安裝Oh My Posh </span></span><br><span class=\"line\">$ winget install --<span class=\"built_in\">id</span> JanDeDobbeleer.OhMyPosh</span><br></pre></td></tr></table></figure>\n<!--more-->\n<h4 id=\"設置PowerShell\"><a href=\"#設置PowerShell\" class=\"headerlink\" title=\"設置PowerShell\"></a>設置PowerShell</h4><figure class=\"highlight powershell\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># 查看所有可用的主題</span></span><br><span class=\"line\"><span class=\"variable\">$</span> <span class=\"built_in\">Get-PoshThemes</span></span><br></pre></td></tr></table></figure>\n\n<figure class=\"highlight powershell\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># C:\\Users\\tpdnx\\Documents\\WindowsPowerShell\\Microsoft.PowerShell_profile.ps1</span></span><br><span class=\"line\"><span class=\"variable\">$</span> notepad <span class=\"variable\">$PROFILE</span></span><br></pre></td></tr></table></figure>\n\n<figure class=\"highlight shell\"><table><tr><td class=\"code\"><pre><span class=\"line\">oh-my-posh init pwsh --config &quot;$env:POSH_THEMES_PATH\\ys.omp.json&quot; | Invoke-Expression</span><br></pre></td></tr></table></figure>\n\n<figure class=\"highlight powershell\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># reload your profile for the changes to take effect</span></span><br><span class=\"line\"><span class=\"variable\">$</span> . <span class=\"variable\">$PROFILE</span></span><br></pre></td></tr></table></figure>\n\n<figure class=\"highlight powershell\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># C:\\Users\\tpdnx\\AppData\\Local\\Programs\\oh-my-posh\\themes</span></span><br><span class=\"line\"><span class=\"variable\">$</span> <span class=\"built_in\">echo</span> <span class=\"variable\">$env:POSH_THEMES_PATH</span></span><br></pre></td></tr></table></figure>\n\n<h4 id=\"設置Command-Prompt\"><a href=\"#設置Command-Prompt\" class=\"headerlink\" title=\"設置Command Prompt\"></a>設置Command Prompt</h4><figure class=\"highlight bash\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># 建立主題目錄</span></span><br><span class=\"line\">$ <span class=\"built_in\">mkdir</span> %USERPROFILE%/Poshthemes</span><br></pre></td></tr></table></figure>\n\n<figure class=\"highlight bash\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># 下載主題</span></span><br><span class=\"line\">$ curl -s https://github.com/JanDeDobbeleer/oh-my-posh/releases/latest/download/themes.zip</span><br></pre></td></tr></table></figure>\n\n<figure class=\"highlight bash\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># 設置主題</span></span><br><span class=\"line\">$ notepad C:\\Users\\tpdnx\\AppData\\Local\\clink\\oh-my-posh.lua</span><br></pre></td></tr></table></figure>\n\n<figure class=\"highlight lua\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"built_in\">load</span>(<span class=\"built_in\">io</span>.<span class=\"built_in\">popen</span>(<span class=\"string\">&#x27;oh-my-posh init cmd --config C:/Users/tpdnx/Poshthemes/jandedobbeleer.omp.json&#x27;</span>):<span class=\"built_in\">read</span>(<span class=\"string\">&quot;*a&quot;</span>))()</span><br></pre></td></tr></table></figure>","categories":["應用工具"],"tags":["OhMyPosh"]},{"title":"在Bash安裝命令行增強工具X-CMD","url":"/2024/09/22/%E5%9C%A8Bash%E5%AE%89%E8%A3%9D%E5%91%BD%E4%BB%A4%E8%A1%8C%E5%A2%9E%E5%BC%B7%E5%B7%A5%E5%85%B7X-CMD/","content":"<p><img src=\"/images/xcmd.png\"></p>\n<span id=\"more\"></span>\n<h4 id=\"下載安裝\"><a href=\"#下載安裝\" class=\"headerlink\" title=\"下載安裝\"></a>下載安裝</h4><figure class=\"highlight bash\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># 為Windows用戶設計的安裝/啟動模式</span></span><br><span class=\"line\">$ curl https://get.x-cmd.com/x.bat -o xcmd.bat</span><br></pre></td></tr></table></figure>\n\n<figure class=\"highlight bash\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># Linux/macOS/WSL/Cygwin/Mignw/Git-Bash</span></span><br><span class=\"line\">$ <span class=\"built_in\">eval</span> <span class=\"string\">&quot;<span class=\"subst\">$(curl https://get.x-cmd.com)</span>&quot;</span></span><br></pre></td></tr></table></figure>\n\n<figure class=\"highlight bash\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># Linux/macOS/WSL/Cygwin/Mignw/Git-Bash</span></span><br><span class=\"line\">$ <span class=\"built_in\">eval</span> <span class=\"string\">&quot;<span class=\"subst\">$(wget -O- https://get.x-cmd.com)</span>&quot;</span></span><br></pre></td></tr></table></figure>\n\n<h4 id=\"更新版本\"><a href=\"#更新版本\" class=\"headerlink\" title=\"更新版本\"></a>更新版本</h4><figure class=\"highlight bash\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># 更新X-CMD至最新版本</span></span><br><span class=\"line\">$ x upgrade</span><br></pre></td></tr></table></figure>","categories":["應用工具"],"tags":["X-CMD"]},{"title":"使用Starship美化命令提示字元","url":"/2024/09/22/%E4%BD%BF%E7%94%A8Starship%E7%BE%8E%E5%8C%96%E5%91%BD%E4%BB%A4%E6%8F%90%E7%A4%BA%E5%AD%97%E5%85%83/","content":"<p><img src=\"/images/starship.png\"></p>\n<span id=\"more\"></span>\n<h4 id=\"快速開始\"><a href=\"#快速開始\" class=\"headerlink\" title=\"快速開始\"></a>快速開始</h4><figure class=\"highlight bash\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># 下載Nerd Font，確保命令提示字元的特殊字符可以被正確顯示</span></span><br><span class=\"line\">- https://www.nerdfonts.com/</span><br></pre></td></tr></table></figure>\n\n<figure class=\"highlight bash\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># 安裝Clink</span></span><br><span class=\"line\">$ winget install chrisant996.Clink</span><br></pre></td></tr></table></figure>\n\n<figure class=\"highlight bash\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># 安裝Starship</span></span><br><span class=\"line\">$ winget install --<span class=\"built_in\">id</span> Starship.Starship</span><br></pre></td></tr></table></figure>\n\n<h4 id=\"設定Command-Prompt\"><a href=\"#設定Command-Prompt\" class=\"headerlink\" title=\"設定Command Prompt\"></a>設定Command Prompt</h4><figure class=\"highlight bash\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># Set up command prompt to use Starship</span></span><br><span class=\"line\">$ code %LocalAppData%\\clink\\starship.lua</span><br></pre></td></tr></table></figure>\n\n<figure class=\"highlight lua\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"built_in\">load</span>(<span class=\"built_in\">io</span>.<span class=\"built_in\">popen</span>(<span class=\"string\">&#x27;starship init cmd&#x27;</span>):<span class=\"built_in\">read</span>(<span class=\"string\">&quot;*a&quot;</span>))()</span><br></pre></td></tr></table></figure>\n\n<h4 id=\"設定PowerShell\"><a href=\"#設定PowerShell\" class=\"headerlink\" title=\"設定PowerShell\"></a>設定PowerShell</h4><figure class=\"highlight bash\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># Set up PowerShell to use Starship</span></span><br><span class=\"line\">$ code <span class=\"variable\">$PROFILE</span></span><br></pre></td></tr></table></figure>\n\n<figure class=\"highlight shell\"><table><tr><td class=\"code\"><pre><span class=\"line\">Invoke-Expression (&amp;starship init powershell)</span><br></pre></td></tr></table></figure>","categories":["應用工具"],"tags":["Starship"]},{"title":"部署Hexo到GitHub Pages","url":"/2024/09/21/%E9%83%A8%E7%BD%B2Hexo%E5%88%B0GitHub-Pages/","content":"<p><img src=\"/images/hexopages.jpg\"></p>\n<span id=\"more\"></span>\n<h4 id=\"操作步驟\"><a href=\"#操作步驟\" class=\"headerlink\" title=\"操作步驟\"></a>操作步驟</h4><ol>\n<li>建立一個與GitHub帳號同名的儲存庫，例如: <code>tpdnxu.github.io</code></li>\n<li>安裝部署到GitHub的相關套件</li>\n<li>修改配置文件的Deployment設定</li>\n<li>執行部署命令<!-- more --></li>\n</ol>\n<h4 id=\"操作使用\"><a href=\"#操作使用\" class=\"headerlink\" title=\"操作使用\"></a>操作使用</h4><figure class=\"highlight bash\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># 安裝Git部署套件</span></span><br><span class=\"line\">$ npm install hexo-deployer-git --save</span><br></pre></td></tr></table></figure>\n\n<figure class=\"highlight bash\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># 編輯配置文件</span></span><br><span class=\"line\">$ cursor _confiy.yml</span><br></pre></td></tr></table></figure>\n\n<figure class=\"highlight yaml\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># URL</span></span><br><span class=\"line\"><span class=\"attr\">url:</span> <span class=\"string\">https://tpdnxu.github.io</span></span><br><span class=\"line\"><span class=\"attr\">permalink:</span> <span class=\"string\">:year/:month/:day/:title/</span></span><br><span class=\"line\"><span class=\"attr\">permalink_defaults:</span></span><br><span class=\"line\"><span class=\"attr\">pretty_urls:</span></span><br><span class=\"line\">  <span class=\"attr\">trailing_index:</span> <span class=\"literal\">true</span> <span class=\"comment\"># Set to false to remove trailing &#x27;index.html&#x27; from permalinks</span></span><br><span class=\"line\">  <span class=\"attr\">trailing_html:</span> <span class=\"literal\">true</span> <span class=\"comment\"># Set to false to remove trailing &#x27;.html&#x27; from permalinks</span></span><br><span class=\"line\"></span><br><span class=\"line\"><span class=\"comment\"># Deployment</span></span><br><span class=\"line\"><span class=\"attr\">deploy:</span></span><br><span class=\"line\">  <span class=\"attr\">type:</span> <span class=\"string\">git</span></span><br><span class=\"line\">  <span class=\"attr\">repo:</span> <span class=\"string\">git@github.com:tpdnxu/tpdnxu.github.io.git</span></span><br><span class=\"line\">  <span class=\"attr\">branch:</span> <span class=\"string\">master</span></span><br></pre></td></tr></table></figure>\n\n<figure class=\"highlight bash\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># 直接部署檔案到GitHub，不用暫存提交</span></span><br><span class=\"line\">$ hexo clean &amp;&amp; hexo deploy --generate</span><br></pre></td></tr></table></figure>","categories":["應用工具"],"tags":["Hexo"]},{"title":"在Linux系統安裝Warp","url":"/2024/09/22/%E5%9C%A8Linux%E7%B3%BB%E7%B5%B1%E5%AE%89%E8%A3%9DWarp/","content":"<p><img src=\"/images/warp.jpg\"></p>\n<span id=\"more\"></span>\n<h4 id=\"下載安裝-Ubuntu-22\"><a href=\"#下載安裝-Ubuntu-22\" class=\"headerlink\" title=\"下載安裝(Ubuntu-22)\"></a>下載安裝(Ubuntu-22)</h4><figure class=\"highlight bash\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># 下載</span></span><br><span class=\"line\">$ wget --content-disposition https://app.warp.dev/download\\?package\\=deb .</span><br></pre></td></tr></table></figure>\n\n<figure class=\"highlight bash\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># 安裝</span></span><br><span class=\"line\">$ <span class=\"built_in\">sudo</span> dpkg -i warp-terminal_0.2024.09.10.08.02.stable.01_amd64.deb</span><br></pre></td></tr></table></figure>\n\n<h4 id=\"下載安裝-CentOS9\"><a href=\"#下載安裝-CentOS9\" class=\"headerlink\" title=\"下載安裝(CentOS9)\"></a>下載安裝(CentOS9)</h4><figure class=\"highlight bash\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># 下載</span></span><br><span class=\"line\">$ wget --content-disposition https://app.warp.dev/download\\?package\\=rpm .</span><br></pre></td></tr></table></figure>\n\n<figure class=\"highlight bash\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># 安裝</span></span><br><span class=\"line\">$ <span class=\"built_in\">sudo</span> dnf install warp-terminal-v0.2024.09.10.08.02.stable_01-1.x86_64.rpm</span><br></pre></td></tr></table></figure>\n\n<h4 id=\"運行啟動\"><a href=\"#運行啟動\" class=\"headerlink\" title=\"運行啟動\"></a>運行啟動</h4><figure class=\"highlight bash\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># 啟動Wrap</span></span><br><span class=\"line\">$ warp-terminal</span><br></pre></td></tr></table></figure>\n\n<h4 id=\"錯誤排除\"><a href=\"#錯誤排除\" class=\"headerlink\" title=\"錯誤排除\"></a>錯誤排除</h4><figure class=\"highlight bash\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># 缷載/移除Warp後先安裝依賴再重新安裝Warp</span></span><br><span class=\"line\">$ <span class=\"built_in\">sudo</span> apt remove warp-terminal</span><br></pre></td></tr></table></figure>\n\n<figure class=\"highlight bash\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># 安裝時缺少依賴套件</span></span><br><span class=\"line\">$ apt-get install fontconfig libegl1 libwayland-client0 libwayland-egl1 libxcursor1 </span><br><span class=\"line\">\\ libxi6 libxkbcommon-x11-0</span><br></pre></td></tr></table></figure>\n\n<figure class=\"highlight bash\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># 啟動時沒有彈出Warp終端</span></span><br><span class=\"line\">$ <span class=\"built_in\">sudo</span> apt install xdg-utils</span><br></pre></td></tr></table></figure>","categories":["應用工具"],"tags":["Warp"]},{"title":"快速開始使用Hexo","url":"/2024/09/20/%E5%BF%AB%E9%80%9F%E9%96%8B%E5%A7%8B%E4%BD%BF%E7%94%A8Hexo/","content":"<p><img src=\"/images/hexo.jpg\"></p>\n<span id=\"more\"></span>\n<h4 id=\"下載安裝\"><a href=\"#下載安裝\" class=\"headerlink\" title=\"下載安裝\"></a>下載安裝</h4><figure class=\"highlight bash\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># Install Hexo</span></span><br><span class=\"line\">$ npm install hexo-cli -g</span><br></pre></td></tr></table></figure>\n<!-- more -->\n<h4 id=\"建立網站\"><a href=\"#建立網站\" class=\"headerlink\" title=\"建立網站\"></a>建立網站</h4><figure class=\"highlight bash\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># create a site</span></span><br><span class=\"line\">$ hexo init blog</span><br></pre></td></tr></table></figure>\n\n<h4 id=\"設置主題\"><a href=\"#設置主題\" class=\"headerlink\" title=\"設置主題\"></a>設置主題</h4><figure class=\"highlight bash\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># 切換至blog目錄</span></span><br><span class=\"line\">$ <span class=\"built_in\">cd</span> blog</span><br></pre></td></tr></table></figure>\n\n<figure class=\"highlight bash\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># 下載主題</span></span><br><span class=\"line\">$ git <span class=\"built_in\">clone</span> https://github.com/theme-next/hexo-theme-next.git themes\\next</span><br></pre></td></tr></table></figure>\n\n<figure class=\"highlight bash\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># 編輯配置文件</span></span><br><span class=\"line\">$ cursor _config.yml</span><br></pre></td></tr></table></figure>\n\n<figure class=\"highlight yaml\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># Extensions</span></span><br><span class=\"line\"><span class=\"attr\">theme:</span> <span class=\"string\">next</span></span><br></pre></td></tr></table></figure>\n\n<h4 id=\"運行網站\"><a href=\"#運行網站\" class=\"headerlink\" title=\"運行網站\"></a>運行網站</h4><figure class=\"highlight bash\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># start the server</span></span><br><span class=\"line\">$ hexo server</span><br></pre></td></tr></table></figure>\n\n<figure class=\"highlight bash\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\"># 訪問網站</span></span><br><span class=\"line\">$ http://localhost:4000</span><br></pre></td></tr></table></figure>","categories":["應用工具"],"tags":["Hexo"]}]